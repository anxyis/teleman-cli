#!/bin/bash
# TeleMan Playground - Simple Installer

set -e

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

INSTALL_DIR="$HOME/teleman-playground-termux"
REPO_URL="git@github.com:anxyis/teleman-playground-termux.git"

echo -e "${CYAN}╔══════════════════════════════════════════════════════════╗${NC}"
echo -e "${CYAN}║         🚀 TeleMan Playground Installer                  ║${NC}"
echo -e "${CYAN}╚══════════════════════════════════════════════════════════╝${NC}"
echo ""

# Install ICU library first (required for Node.js to work)
echo -e "${BLUE}ℹ${NC} Installing ICU library (required for Node.js)..."
pkg install libicu -y -q 2>/dev/null || true
echo -e "${GREEN}✓${NC} ICU library installed"

# Check if we're already in a teleman-playground-termux directory
if [[ "$PWD" == *"teleman-playground-termux"* ]] && [ -f "package.json" ]; then
    echo -e "${GREEN}✓${NC} Already in TeleMan directory!"
    INSTALL_DIR="$PWD"
else
    # Check if Node.js works
    if ! node --version &> /dev/null; then
        echo -e "${YELLOW}⚠${NC} Node.js is broken. Fixing it..."
        pkg uninstall nodejs nodejs-lts npm -y -q 2>/dev/null || true
        pkg install nodejs -y
    fi
    
    echo -e "${GREEN}✓${NC} Node.js is working ($(node --version))"
    
    # Remove old installation if it exists and we're not inside it
    if [ -d "$INSTALL_DIR" ] && [ "$PWD" != "$INSTALL_DIR" ]; then
        echo -e "${YELLOW}⚠${NC} Removing old installation..."
        rm -rf "$INSTALL_DIR"
    fi
    
    # Clone repository
    echo -e "${BLUE}ℹ${NC} Cloning repository..."
    git clone --depth 1 "$REPO_URL" "$INSTALL_DIR"
    echo -e "${GREEN}✓${NC} Repository cloned"
    
    # Change to install directory
    cd "$INSTALL_DIR"
fi

# Install dependencies
echo ""
echo -e "${BLUE}ℹ${NC} Installing npm dependencies..."
cd "$INSTALL_DIR"
npm install
echo -e "${GREEN}✓${NC} Dependencies installed"

# Setup environment
echo ""
echo -e "${BLUE}ℹ${NC} Setting up environment..."
if [ ! -f ".env" ]; then
    cp .env.example .env 2>/dev/null || echo "VITE_API_BASE_URL=http://localhost:3000" > .env
fi
mkdir -p data/backgrounds data/logs data/avatars data/themes data/fonts temp_work
echo -e "${GREEN}✓${NC} Environment configured"

# Build the app
echo ""
echo -e "${BLUE}ℹ${NC} Building the app..."
npm run build
echo -e "${GREEN}✓${NC} Build complete"

# Create shortcuts
echo ""
echo -e "${BLUE}ℹ${NC} Creating shortcuts..."

# Remove old shortcuts
for profile in "$HOME/.bashrc" "$HOME/.zshrc" "$HOME/.profile"; do
    if [ -f "$profile" ]; then
        sed -i '/alias start-tg=/d' "$profile" 2>/dev/null || true
        sed -i '/alias stop-tg=/d' "$profile" 2>/dev/null || true
    fi
done

# Add new shortcuts
cat >> "$HOME/.bashrc" << 'EOF'

# TeleMan Shortcuts
alias start-tg='cd ~/teleman-playground-termux && npm run server'
alias stop-tg='pkill -f "node.*server" || echo "TeleMan stopped"'
EOF

source "$HOME/.bashrc" 2>/dev/null || true
echo -e "${GREEN}✓${NC} Shortcuts created"

# DONE
echo ""
echo -e "${GREEN}╔══════════════════════════════════════════════════════════╗${NC}"
echo -e "${GREEN}║           ✅ Installation Complete!                      ║${NC}"
echo -e "${GREEN}╚══════════════════════════════════════════════════════════╝${NC}"
echo ""
echo -e "${CYAN}Start TeleMan:${NC}"
echo ""
echo "  ${BLUE}start-tg${NC}"
echo ""
echo "  Then open ${BLUE}http://localhost:3000${NC} in your browser"
echo ""
echo -e "${YELLOW}If start-tg doesn't work:${NC}"
echo "  ${BLUE}source ~/.bashrc${NC}"
echo "  ${BLUE}start-tg${NC}"
echo ""
echo -e "${CYAN}Enjoy TeleMan! 🎉${NC}"
