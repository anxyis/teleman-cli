import { useState } from 'react';
import { DynamicIcon } from './common/DynamicIcon';
import axios from 'axios';
import { ResponsiveModal } from './common/ResponsiveModal';

interface PresetManagerProps {
    presets: any[];
    onClose: () => void;
    onRefresh: () => void;
}

export function PresetManager({ presets, onClose, onRefresh }: PresetManagerProps) {
    const [editingId, setEditingId] = useState<string | null>(null);
    const [name, setName] = useState('');
    const [loading, setLoading] = useState(false);

    // Filter Settings
    const [minSize, setMinSize] = useState(0);
    const [maxSize, setMaxSize] = useState(0);
    const [allowedExts, setAllowedExts] = useState('');
    const [archiveMode, setArchiveMode] = useState<'none' | 'zip' | '7z'>('none');
    const [archiveSize, setArchiveSize] = useState(0);
    const [archivePassword, setArchivePassword] = useState('');

    const API_BASE = import.meta.env.VITE_API_BASE_URL ?? '';

    const handleEdit = (preset: any) => {
        setEditingId(preset.id);
        setName(preset.name);
        const r = JSON.parse(preset.rules_json);
        setMinSize(Math.round((r.min_size || 0) / 1024 / 1024));
        setMaxSize(Math.round((r.max_size || 0) / 1024 / 1024));
        setAllowedExts((r.extensions || []).join(', '));
        setArchiveMode(r.archiveMode || 'none');
        setArchiveSize(Math.round((r.archiveSize || 0) / 1024 / 1024));
        setArchivePassword(r.archivePassword || '');
    };

    const handleCreateNew = () => {
        setEditingId('new');
        setName('');
        setMinSize(0);
        setMaxSize(0);
        setAllowedExts('');
        setArchiveMode('none');
        setArchiveSize(0);
        setArchivePassword('');
    };

    const handleSave = async () => {
        if (!name) return alert("Name is required");
        setLoading(true);

        const extensions = allowedExts.split(',').map(s => s.trim().toLowerCase()).filter(s => s !== '');

        const rules = {
            extensions,
            min_size: minSize * 1024 * 1024,
            max_size: maxSize * 1024 * 1024,
            archiveMode: archiveMode,
            archiveSize: archiveSize * 1024 * 1024,
            archivePassword: archivePassword || undefined
        };

        try {
            if (editingId === 'new') {
                await axios.post(`${API_BASE}/api/presets`, { name, rules });
            } else {
                await axios.put(`${API_BASE}/api/presets/${editingId}`, { name, rules });
            }
            onRefresh();
            setEditingId(null);
        } catch (e) {
            alert("Failed to save preset");
        } finally {
            setLoading(false);
        }
    };

    const handleDelete = async (e: React.MouseEvent, id: string) => {
        e.stopPropagation();
        if (!confirm("Are you sure you want to delete this preset?")) return;

        try {
            await axios.delete(`${API_BASE}/api/presets/${id}`);
            onRefresh();
            if (editingId === id) setEditingId(null);
        } catch (error) {
            alert("Failed to delete preset.");
        }
    };

    return (
        <ResponsiveModal
            isOpen={true}
            onClose={onClose}
            title="Sync Presets"
            widthClass="max-w-3xl"
        >
            <div className="flex flex-col h-full md:h-[650px]">
                {editingId ? (
                    <div className="flex-1 overflow-y-auto pr-2 space-y-6 animate-in slide-in-from-right-4 duration-200">
                        <button onClick={() => setEditingId(null)} className="flex items-center gap-2 text-sm text-text-muted hover:text-text-main transition-colors">
                            <DynamicIcon name="arrow-left" size={16} /> Back to List
                        </button>

                        <div className="space-y-4">
                            <div className="space-y-2">
                                <label className="text-xs font-bold text-text-muted uppercase">Preset Name</label>
                                <input className="w-full bg-surface border border-border rounded-xl p-4 text-text-main outline-none focus:ring-2 focus:ring-primary/50" value={name} onChange={e => setName(e.target.value)} placeholder="e.g. High Quality Video" />
                            </div>

                            <div className="grid grid-cols-1 sm:grid-cols-2 gap-6">
                                <div className="space-y-4">
                                    <h4 className="text-xs font-bold text-primary uppercase tracking-widest flex items-center gap-2">
                                        <DynamicIcon name="beaker" size={14} /> Filtering Rules
                                    </h4>
                                    <div className="space-y-3 p-4 bg-canvas/50 border border-border rounded-xl">
                                        <div className="space-y-1">
                                            <label className="text-[10px] font-bold text-text-muted uppercase">Allowed Extensions</label>
                                            <input className="w-full bg-surface border border-border rounded-lg p-2.5 text-xs text-text-main font-mono" value={allowedExts} onChange={e => setAllowedExts(e.target.value)} placeholder="mp4, mkv, mov" />
                                        </div>
                                        <div className="grid grid-cols-2 gap-3">
                                            <div className="space-y-1">
                                                <label className="text-[10px] font-bold text-text-muted uppercase">Min Size (MB)</label>
                                                <input type="number" className="w-full bg-surface border border-border rounded-lg p-2.5 text-xs text-text-main" value={minSize} onChange={e => setMinSize(Number(e.target.value))} />
                                            </div>
                                            <div className="space-y-1">
                                                <label className="text-[10px] font-bold text-text-muted uppercase">Max Size (MB)</label>
                                                <input type="number" className="w-full bg-surface border border-border rounded-lg p-2.5 text-xs text-text-main" value={maxSize} onChange={e => setMaxSize(Number(e.target.value))} />
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div className="space-y-4">
                                    <h4 className="text-xs font-bold text-pink-400 uppercase tracking-widest flex items-center gap-2">
                                        <DynamicIcon name="archive" size={14} /> Auto-Archiving
                                    </h4>
                                    <div className="space-y-3 p-4 bg-canvas/50 border border-border rounded-xl">
                                        <div className="space-y-1">
                                            <label className="text-[10px] font-bold text-text-muted uppercase">Compression Mode</label>
                                            <select className="w-full bg-surface border border-border rounded-lg p-2.5 text-xs text-text-main" value={archiveMode} onChange={e => setArchiveMode(e.target.value as any)}>
                                                <option value="none">Disabled (Send Raw)</option>
                                                <option value="zip">ZIP (Fast)</option>
                                                <option value="7z">7-Zip (Ultra)</option>
                                            </select>
                                        </div>
                                        {archiveMode !== 'none' && (
                                            <div className="space-y-3 animate-in fade-in slide-in-from-top-2">
                                                <div className="space-y-1">
                                                    <label className="text-[10px] font-bold text-text-muted uppercase">Split Volume Size (MB)</label>
                                                    <input type="number" className="w-full bg-surface border border-border rounded-lg p-2.5 text-xs text-text-main" value={archiveSize} onChange={e => setArchiveSize(Number(e.target.value))} placeholder="e.g. 1900" />
                                                </div>
                                                <div className="space-y-1">
                                                    <label className="text-[10px] font-bold text-text-muted uppercase">Password Protect</label>
                                                    <input className="w-full bg-surface border border-border rounded-lg p-2.5 text-xs text-text-main" value={archivePassword} onChange={e => setArchivePassword(e.target.value)} placeholder="Optional" />
                                                </div>
                                            </div>
                                        )}
                                    </div>
                                </div>
                            </div>
                        </div>

                        <button onClick={handleSave} disabled={loading} className="w-full flex items-center justify-center gap-2 py-4 bg-primary hover:bg-primary-hover text-on-primary font-bold rounded-xl shadow-lg shadow-primary/20 transition-all active:scale-95 disabled:opacity-50">
                            {loading ? <DynamicIcon name="loader" size={20} className="animate-spin" /> : <DynamicIcon name="save" size={20} />}
                            {editingId === 'new' ? 'Create Preset' : 'Save Changes'}
                        </button>
                    </div>
                ) : (
                    <div className="flex flex-col h-full">
                        <div className="flex items-center justify-between mb-4 px-1">
                            <p className="text-xs text-text-muted font-bold uppercase tracking-widest">Available Presets</p>
                            <button onClick={handleCreateNew} className="flex items-center gap-2 px-3 py-1.5 bg-primary/10 text-primary hover:bg-primary text-xs font-bold rounded-lg transition-all active:scale-95">
                                <DynamicIcon name="plus" size={14} /> New Preset
                            </button>
                        </div>

                        <div className="flex-1 overflow-y-auto space-y-2 pr-1">
                            {presets.map((p) => (
                                <div key={p.id} onClick={() => handleEdit(p)} className="bg-surface border border-border p-4 rounded-xl flex items-center justify-between group hover:border-primary/40 cursor-pointer transition-all shadow-sm">
                                    <div className="flex items-center gap-4">
                                        <div className="p-2.5 bg-surface-highlight text-text-muted group-hover:text-primary transition-colors rounded-lg">
                                            <DynamicIcon name="file-json" size={20} />
                                        </div>
                                        <div>
                                            <h4 className="text-sm font-bold text-text-main">{p.name}</h4>
                                            <p className="text-[10px] text-text-muted uppercase font-bold tracking-wider mt-0.5">
                                                {JSON.parse(p.rules_json).extensions?.length || 0} Exts • {JSON.parse(p.rules_json).archiveMode || 'No Archive'}
                                            </p>
                                        </div>
                                    </div>
                                    <div className="flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                        <button onClick={(e) => handleDelete(e, p.id)} className="p-2 text-text-muted hover:text-red-400 hover:bg-red-500/10 rounded-lg transition-colors">
                                            <DynamicIcon name="trash" size={18} />
                                        </button>
                                    </div>
                                </div>
                            ))}

                            {presets.length === 0 && (
                                <div className="flex flex-col items-center justify-center p-12 text-text-muted opacity-30 italic">
                                    <DynamicIcon name="beaker" size={48} className="mb-4" />
                                    <p>No presets found</p>
                                </div>
                            )}
                        </div>
                    </div>
                )}
            </div>
        </ResponsiveModal>
    );
}
